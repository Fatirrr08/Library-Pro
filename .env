# LibraryPro - Database Configuration
# Copy this file to .env and fill in your values
# These values are read by DBConnection.java

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=librarymanagamentsystem
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_SSL_MODE=PREFERRED

# Untuk TiDB Cloud, gunakan: MYSQL_SSL_MODE=REQUIRED
# Railway MySQL default: Cukup PREFERRED (atau hapus, defaultnya PREFERRED)
